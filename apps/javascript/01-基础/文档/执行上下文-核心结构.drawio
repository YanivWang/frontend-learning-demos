<mxfile host="Electron" agent="Codex">
  <diagram id="execution-context-core" name="执行上下文核心结构">
    <mxGraphModel dx="2570" dy="1442" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1654" pageHeight="1169" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <mxCell id="title" parent="1" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=28;fontStyle=1;fontColor=#111827;" value="执行上下文（Execution Context）核心结构" vertex="1">
          <mxGeometry height="50" width="680" x="260" y="30" as="geometry" />
        </mxCell>
        <mxCell id="outer" parent="1" style="rounded=1;whiteSpace=wrap;html=1;arcSize=5;fillColor=#f5f2ec;strokeColor=#7a7a73;strokeWidth=1.5;" value="" vertex="1">
          <mxGeometry height="1075" width="1035" x="85" y="95" as="geometry" />
        </mxCell>
        <mxCell id="outer-label" parent="1" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=top;whiteSpace=wrap;rounded=0;fontSize=24;fontColor=#4b5563;spacingLeft=0;" value="&lt;b&gt;执行上下文 EC&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size: 18px;&quot;&gt;代码执行时创建，记录当前代码运行需要的环境信息&lt;/font&gt;" vertex="1">
          <mxGeometry height="70" width="650" x="135" y="135" as="geometry" />
        </mxCell>
        <mxCell id="lex" parent="1" style="rounded=1;whiteSpace=wrap;html=1;arcSize=3;fillColor=#ecebff;strokeColor=#6857d9;strokeWidth=1.4;" value="" vertex="1">
          <mxGeometry height="315" width="950" x="125" y="220" as="geometry" />
        </mxCell>
        <mxCell id="lex-title" parent="1" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=top;whiteSpace=wrap;rounded=0;fontSize=25;fontColor=#3730a3;" value="&lt;b&gt;LexicalEnvironment（词法环境）&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size: 20px;&quot;&gt;管理 let / const / class、块级作用域绑定，以及词法作用域链&lt;/font&gt;" vertex="1">
          <mxGeometry height="60" width="820" x="175" y="255" as="geometry" />
        </mxCell>
        <mxCell id="lex-record" parent="1" style="rounded=1;whiteSpace=wrap;html=1;arcSize=4;fillColor=#dff5ef;strokeColor=#047857;strokeWidth=1.2;fontSize=21;fontColor=#065f46;align=center;verticalAlign=middle;spacing=14;" value="&lt;b&gt;EnvironmentRecord&lt;/b&gt;&lt;br&gt;保存当前词法作用域内的绑定&lt;br&gt;&lt;br&gt;示例：let name = &amp;quot;Sarah&amp;quot;&lt;br&gt;示例：const age = 22&lt;br&gt;&lt;font style=&quot;font-size: 17px;&quot;&gt;初始化前处于 TDZ，不能读取&lt;/font&gt;" vertex="1">
          <mxGeometry height="165" width="400" x="170" y="330" as="geometry" />
        </mxCell>
        <mxCell id="lex-outer" parent="1" style="rounded=1;whiteSpace=wrap;html=1;arcSize=4;fillColor=#fff1ec;strokeColor=#b45309;strokeWidth=1.2;fontSize=21;fontColor=#8a2f11;align=center;verticalAlign=middle;spacing=14;" value="&lt;b&gt;outer 引用&lt;/b&gt;&lt;br&gt;指向外层 LexicalEnvironment&lt;br&gt;&lt;br&gt;当前环境找不到变量时，沿 outer 继续向外查找&lt;br&gt;全局环境的 outer 通常是 null" vertex="1">
          <mxGeometry height="165" width="390" x="635" y="330" as="geometry" />
        </mxCell>
        <mxCell id="var" parent="1" style="rounded=1;whiteSpace=wrap;html=1;arcSize=3;fillColor=#eef2ff;strokeColor=#6857d9;strokeWidth=1.4;" value="" vertex="1">
          <mxGeometry height="305" width="950" x="125" y="575" as="geometry" />
        </mxCell>
        <mxCell id="var-title" parent="1" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=top;whiteSpace=wrap;rounded=0;fontSize=25;fontColor=#3730a3;" value="&lt;b&gt;VariableEnvironment（变量环境）&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size: 20px;&quot;&gt;主要保存 var 声明绑定；函数 EC 创建时常与 LexicalEnvironment 起点相同&lt;/font&gt;" vertex="1">
          <mxGeometry height="60" width="850" x="175" y="607" as="geometry" />
        </mxCell>
        <mxCell id="var-record" parent="1" style="rounded=1;whiteSpace=wrap;html=1;arcSize=4;fillColor=#dff5ef;strokeColor=#047857;strokeWidth=1.2;fontSize=21;fontColor=#065f46;align=center;verticalAlign=middle;spacing=14;" value="&lt;b&gt;EnvironmentRecord&lt;/b&gt;&lt;br&gt;保存 var 声明的变量绑定&lt;br&gt;&lt;br&gt;示例：var x = 1&lt;br&gt;提升后初始值为 undefined" vertex="1">
          <mxGeometry height="150" width="400" x="170" y="690" as="geometry" />
        </mxCell>
        <mxCell id="var-outer" parent="1" style="rounded=1;whiteSpace=wrap;html=1;arcSize=4;fillColor=#fff1ec;strokeColor=#b45309;strokeWidth=1.2;fontSize=21;fontColor=#8a2f11;align=center;verticalAlign=middle;spacing=14;" value="&lt;b&gt;outer 引用&lt;/b&gt;&lt;br&gt;同样参与作用域链查找&lt;br&gt;&lt;br&gt;理解重点：变量查找沿环境链向外走" vertex="1">
          <mxGeometry height="150" width="390" x="635" y="690" as="geometry" />
        </mxCell>
        <mxCell id="this" parent="1" style="rounded=1;whiteSpace=wrap;html=1;arcSize=3;fillColor=#fff4df;strokeColor=#b7791f;strokeWidth=1.3;fontSize=22;fontColor=#7c3f00;align=left;verticalAlign=middle;spacing=18;spacingLeft=34;fillStyle=solid;" value="&lt;b&gt;ThisBinding（this 绑定）&lt;/b&gt;&lt;br&gt;记录当前执行上下文中的 this 值&lt;br&gt;&lt;br&gt;浏览器普通脚本全局：this 通常是 window；ES 模块顶层：this 是 undefined&lt;br&gt;普通函数 this 取决于调用方式；严格模式普通调用为 undefined&lt;br&gt;箭头函数没有自己的 this，沿外层词法环境捕获" vertex="1">
          <mxGeometry height="222" width="955" x="125" y="918" as="geometry" />
        </mxCell>
      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
